#include "WiFiS3.h"

// --- Inställningar ---
const char* ssid = "Namn";
const char* pass = "Lösenord"; 

#define LIGHT_SENSOR_PIN A3
#define MOISTURE_SENSOR_PIN A4
#define TEMP_SENSOR_PIN A5
#define PUMP_PIN 7
#define GROWLIGHT_PIN 8

WiFiServer server(80);

// Variabler för sensorer
int moisture = 0, light = 0, temp = 0;
bool pumpOn = false, lightOn = false, autoMode = true;
int moistureThreshold = 500;

void setup() {
  Serial.begin(115200);
  pinMode(PUMP_PIN, OUTPUT);
  pinMode(GROWLIGHT_PIN, OUTPUT);

  if (WiFi.status() == WL_NO_MODULE) {
    Serial.println("WiFi-modul hittades inte!");
    while (true);
  }

  Serial.print("Ansluter till: ");
  Serial.println(ssid);

  while (WiFi.status() != WL_CONNECTED) {
    WiFi.begin(ssid, pass); 
    delay(1000);
    Serial.print(".");
  }

  server.begin();
  Serial.println("\nAnsluten!");
  Serial.print("IP-adress: ");
  Serial.println(WiFi.localIP());
}

void loop() {
  // --- Sensorläsning och Automatik ---
  light = analogRead(LIGHT_SENSOR_PIN);
  moisture = analogRead(MOISTURE_SENSOR_PIN);
  temp = analogRead(TEMP_SENSOR_PIN);

  if (autoMode) {
    pumpOn = (moisture < moistureThreshold);
    // Exempel: lampan tänds om det är mörkt (under 300)
    lightOn = (light < 300); 
  }
  
  digitalWrite(PUMP_PIN, pumpOn ? HIGH : LOW);
  digitalWrite(GROWLIGHT_PIN, lightOn ? HIGH : LOW);

  // --- Hantera Webbrequest ---
  WiFiClient client = server.available();
  if (client) {
    String request = client.readStringUntil('\r');
    
    // 1. ROUTE: Hämta JSON-data (för realtidsuppdatering)
    if (request.indexOf("GET /data") != -1) {
      client.println("HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nConnection: close\r\n\r\n");
      client.print("{\"light\":"); client.print(light);
      client.print(",\"moisture\":"); client.print(moisture);
      client.print(",\"temp\":"); client.print(temp);
      client.print(",\"pump\":"); client.print(pumpOn ? "true":"false");
      client.println("}");
    } 
    
    // 2. ROUTE: Kontrollera inställningar
    else if (request.indexOf("GET /set") != -1) {
      if (request.indexOf("pump=on") != -1) { pumpOn = true; autoMode = false; }
      if (request.indexOf("pump=off") != -1) { pumpOn = false; autoMode = false; }
      if (request.indexOf("mode=auto") != -1) autoMode = true;
      if (request.indexOf("mode=manual") != -1) autoMode = false;
      
      client.println("HTTP/1.1 200 OK\r\nContent-Length: 2\r\nConnection: close\r\n\r\nOK");
    }

    // 3. ROUTE: Huvudsidan (UI)
    else if (request.indexOf("GET / ") != -1) {
      client.println("HTTP/1.1 200 OK\nContent-Type: text/html; charset=utf-8\n\n");
      client.println("<html><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1'><style>");
      client.println("body { background: #111; color: white; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; padding: 20px; }");
      client.println(".card { background: #222; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.5); width: 100%; max-width: 350px; text-align: center; margin-bottom: 20px; }");
      client.println("h2 { color: #44ff44; margin-top: 0; }");
      client.println(".val { font-size: 24px; font-weight: bold; color: #fff; margin: 10px 0; }");
      client.println("button { width: 100%; padding: 15px; margin: 5px 0; font-size: 16px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; }");
      client.println(".btn-on { background: #ff4444; color: white; } .btn-off { background: #444; color: white; } .btn-mode { background: #007bff; color: white; }");
      client.println("</style></head><body>");

      client.println("<h1>Plant Control</h1>");

      // Statuskort
      client.println("<div class='card'><h2>STATUS</h2><div id='stats' class='val'>Laddar...</div></div>");

      // Kontrollkort
      client.println("<div class='card'><h2>PUMP</h2>");
      client.println("<button class='btn-on' onclick=\"fetch('/set?pump=on')\">STARTA PUMP</button>");
      client.println("<button class='btn-off' onclick=\"fetch('/set?pump=off')\">STOPPA PUMP</button></div>");

      client.println("<div class='card'><h2>LÄGE</h2>");
      client.println("<button class='btn-mode' onclick=\"fetch('/set?mode=auto')\">AUTO</button>");
      client.println("<button class='btn-mode' onclick=\"fetch('/set?mode=manual')\">MANUELL</button></div>");

      // Script för uppdatering
      client.println("<script>");
      client.println("function update(){fetch('/data').then(r=>r.json()).then(d=>{");
      client.println("document.getElementById('stats').innerHTML='Ljus: '+d.light+'<br>Fukt: '+d.moisture+'<br>Temp: '+d.temp;");
      client.println("});} setInterval(update, 2000); update();");
      client.println("</script></body></html>");
    }
    
    delay(1);
    client.stop();
  }
}
